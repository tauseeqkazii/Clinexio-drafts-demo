# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Public — visible to the browser. Safe to expose.
# Base URL of the deployed Clinexio API on AWS (no trailing slash).
NEXT_PUBLIC_API_URL=https://clinexio-dev-alb-479089530.eu-west-2.elb.amazonaws.com:8444

# Server-only — never `NEXT_PUBLIC_` prefix.
# Bearer token used by the Next.js API route to authenticate against
# the backend's /api/v1/test/draft-pair endpoint. Must match the
# `DEMO_DRAFT_PAIR_SECRET` env var set on the API server.
DEMO_DRAFT_PAIR_SECRET=replace-me-with-a-long-random-string
